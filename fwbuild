#!/bin/bash
set -eo pipefail

IMAGE="zmkfirmware/zmk-build-arm:stable"
ARTIFACTS_DIR="/tmp/zmk-artifacts"
WORKSPACE_DIR="/tmp/zmk-workspace"
SCRIPT="/work/build-local.sh"
HALF="${1:-both}"

build_half() {
    local board="$1" half="$2"
    echo "=== Building $half half ==="
    podman run --rm \
        -v "$PWD:/work:Z" \
        -v "$ARTIFACTS_DIR:/artifacts:Z" \
        -v "$WORKSPACE_DIR:/workspace:Z" \
        "$IMAGE" \
        bash "$SCRIPT" "$board" "$half" "/workspace"
}

mkdir -p "$ARTIFACTS_DIR"
mkdir -p "$WORKSPACE_DIR"

case "$HALF" in
    left)
        build_half "corneish_zen_left@2//zmk" "left"
        ;;
    right)
        build_half "corneish_zen_right@2//zmk" "right"
        ;;
    both)
        build_half "corneish_zen_left@2//zmk" "left"
        build_half "corneish_zen_right@2//zmk" "right"
        ;;
    clean)
        echo "Removing shared workspace ($WORKSPACE_DIR)..."
        rm -rf "$WORKSPACE_DIR"
        echo "Done. Next build will fetch repos from scratch."
        ;;
    *)
        echo "Usage: $0 [left|right|both|clean]"
        exit 1
        ;;
esac

if [ "$HALF" != "clean" ]; then
    echo ""
    echo "Artifacts in $ARTIFACTS_DIR:"
    ls -lh "$ARTIFACTS_DIR"/*.uf2 2>/dev/null
fi
